{
  "name": "@gentid/auth",
  "version": "1.0.0",
  "description": "GentID Agent Gateway — Express, Next.js, and Cloudflare Worker middleware for AI agent authentication",
  "license": "MIT",
  "homepage": "https://gentid.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/010101G/gentid-auth.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "default": "./dist/express.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "default": "./dist/next.js"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "default": "./dist/cloudflare.js"
    }
  },
  "keywords": [
    "gentid",
    "ai-agent",
    "agent-auth",
    "agent-gateway",
    "middleware",
    "express",
    "nextjs",
    "cloudflare",
    "authentication",
    "authorization",
    "identity",
    "ai",
    "autonomous-agent"
  ],
  "files": ["dist"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "peerDependencies": {
    "express": ">=4",
    "next": ">=13"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "next": { "optional": true }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
